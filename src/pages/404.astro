---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Page not found">
  <main>
    <header class="header">
      <h1 class="header__title">Page not found</h1>
      <p class="header__lead">That page doesn't exist.</p>
    </header>
    <div class="content">
      <p>
        <a href={base}>Go back home</a> and we'll find you a scenario.
      </p>
    </div>
  </main>
</Layout>
