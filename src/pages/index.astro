---
import { getCollection } from 'astro:content';

const scenarios = await getCollection('scenarios');
const slugs = scenarios.map((s) => s.slug);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inclusive Design Scenarios</title>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${base}scenarios/screen-reader`} />
    </noscript>
  </head>
  <body>
    <script define:vars={{ slugs, base }}>
      const slug = slugs[Math.floor(Math.random() * slugs.length)];
      window.location.replace(base + 'scenarios/' + slug);
    </script>
  </body>
</html>
